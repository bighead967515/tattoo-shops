{
  "version": 2,
  "builds": [
    {
      "src": "backend/server/_core/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "options": {
        "installCommand": "pnpm install",
        "buildCommand": "vite build",
        "outputDirectory": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server/_core/index.ts"
    }
  ]
}