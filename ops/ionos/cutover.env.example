# Copy to ops/ionos/cutover.env and edit values before running scripts.
# NOTE: The app runs on Render Web Service. IONOS is used for DNS only.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=theinkednetwork.website
WWW_DOMAIN=www.theinkednetwork.website

# ── IONOS DNS targets ─────────────────────────────────────────────────────────
# Get these values from the Render dashboard under Settings > Custom Domains.
# Use the Render-provided CNAME/ALIAS value — do NOT point to a VM IP.
RENDER_DNS_TARGET=
# e.g. theinkednetwork.website.onrender.com

# Apex A/ALIAS record — only needed if your DNS provider does not support CNAME on apex.
# Leave empty to use CNAME/ALIAS on apex instead.
TARGET_IPV4=
TARGET_IPV6=

# TTL during cutover (seconds) — set low, raise after DNS is stable.
DNS_TTL=300

# ── App runtime (reference only — Render manages the process) ─────────────────
APP_PORT=3000
HEALTH_PATH=/api/health
NODE_ENV=production

# ── Render environment variables ──────────────────────────────────────────────
# Set these in the Render dashboard (Environment tab), NOT in this file.
# PUBLIC_BASE_URL=https://theinkednetwork.website
# CORS_ALLOWED_ORIGINS=https://theinkednetwork.website,https://www.theinkednetwork.website

# ── TLS/HSTS ──────────────────────────────────────────────────────────────────
# Render provisions and renews TLS automatically for custom domains.
# Enable HSTS only after HTTPS is confirmed stable on both hostnames.
ENABLE_HSTS=true
HSTS_VALUE="max-age=31536000; includeSubDomains; preload"

# ── Cutover validation ────────────────────────────────────────────────────────
EXPECTED_HTTP_REDIRECT_CODE=301
EXPECTED_HTTPS_CODE=200
