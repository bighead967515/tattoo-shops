  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch backend/server/_core/index.ts",
    "build": "vite build && node scripts/build-server.mjs",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "build:full": "vite build && git add -f dist/public/assets/ && esbuild backend/server/_core/index.ts --platform=node --bundle --format=esm --outfile=dist/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --external:vite --external:@vitejs/plugin-react --external:vite-tsconfig-paths --external:@playwright/test --external:vitest --external:tsx --external:drizzle-kit --external:esbuild --external:typescript --external:prettier --external:artillery --external:lightningcss --external:@tailwindcss/oxide --external:@tailwindcss/vite --external:tailwindcss --external:@builder.io/vite-plugin-jsx-loc",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:list": "pnpm exec playwright test --list",
    "test:e2e:install": "pnpm exec playwright install --with-deps",
    "customizations:list": "node scripts/validate-customization-files.mjs",
    "customizations:check": "node scripts/validate-customization-files.mjs --strict",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "load:browse": "artillery run tests/load/browsing.yml",
    "load:booking": "artillery run tests/load/booking-flow.yml",
    "load:spike": "artillery run tests/load/spike-test.yml",
    "load:report": "artillery run tests/load/booking-flow.yml --output results.json && artillery report results.json"
  },
