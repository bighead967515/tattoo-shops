        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"Ink Connect Verification <verify@inkconnect.app>\",\n  \"to\": \"{{ $env.ADMIN_ALERT_EMAIL }}\",\n  \"subject\": \"[ESCALATION] License still pending 48h: {{ $('trigger_webhook_license_review').item.json.body.artistName }}\",\n  \"html\": \"<h2>Verification Escalation</h2><p>The license submission for <strong>{{ $('trigger_webhook_license_review').item.json.body.artistName }}</strong> ({{ $('trigger_webhook_license_review').item.json.body.shopName }}) has been pending for over 48 hours.</p><p>Document ID: {{ $('trigger_webhook_license_review').item.json.body.documentId }}</p><p>Submitted: {{ $('trigger_webhook_license_review').item.json.body.submittedAt }}</p><p><a href='{{ $env.APP_BASE_URL }}/admin/verification?doc={{ $('trigger_webhook_license_review').item.json.body.documentId }}'>Review Now</a></p>\"\n}"
      },
