    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/verificationDocuments?id=eq.{{ $('trigger_webhook_license_review').item.json.body.documentId }}&select=ocrProcessedAt,ocrDocumentType,ocrExtractedName,ocrExtractedBusinessName,ocrLicenseNumber,ocrExpirationDate,ocrIssuingAuthority,ocrConfidence,ocrNameMatch,ocrVerdict,ocrVerdictReason,ocrIssues,status",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        }
      },
      "id": "api_supabase_fetch_ocr_2",
      "name": "api_supabase_fetch_ocr_2",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1560, 480],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Use whichever OCR fetch returned data\nconst ocr1 = $('api_supabase_fetch_ocr_1').item?.json;\nconst ocr2 = $('api_supabase_fetch_ocr_2')?.item?.json;\nconst data = (Array.isArray(ocr1) && ocr1.length > 0 && ocr1[0].ocrProcessedAt) ? ocr1[0]\n  : (Array.isArray(ocr2) && ocr2.length > 0) ? ocr2[0]\n  : {};\n\nconst verdictColors = { verified: '#16a34a', needs_review: '#d97706', rejected: '#dc2626' };\nconst body = $('trigger_webhook_license_review').item.json.body;\nreturn [{ json: {\n  ...data,\n  documentId: body.documentId,\n  userId: body.userId,\n  artistId: body.artistId,\n  artistName: body.artistName,\n  shopName: body.shopName,\n  documentType: body.documentType,\n  originalFileName: body.originalFileName,\n  submittedAt: body.submittedAt,\n  verdictColor: verdictColors[data.ocrVerdict] || '#6b7280'\n}}];"
      },
      "id": "transform_build_email_data",
      "name": "transform_build_email_data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.RESEND_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"Ink Connect Verification <verify@inkconnect.app>\",\n  \"to\": \"{{ $env.ADMIN_ALERT_EMAIL }}\",\n  \"subject\": \"License Verification: {{ $json.artistName }} — {{ $json.ocrVerdict || 'Pending OCR' }}\",\n  \"html\": \"<h2>License Verification Submission</h2><table style='border-collapse:collapse;width:100%'><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Artist</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.artistName }} ({{ $json.shopName }})</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Document</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.documentType }} — {{ $json.originalFileName }}</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Submitted</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.submittedAt }}</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>OCR Verdict</strong></td><td style='padding:8px;border:1px solid #e5e7eb;color:{{ $json.verdictColor }}'><strong>{{ $json.ocrVerdict || 'Not processed' }}</strong></td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Confidence</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.ocrConfidence }}%</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Extracted Name</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.ocrExtractedName }} (match: {{ $json.ocrNameMatch }})</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>License #</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.ocrLicenseNumber }}</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Expiry</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.ocrExpirationDate }}</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Issuing Authority</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.ocrIssuingAuthority }}</td></tr><tr><td style='padding:8px;border:1px solid #e5e7eb'><strong>Reason</strong></td><td style='padding:8px;border:1px solid #e5e7eb'>{{ $json.ocrVerdictReason }}</td></tr></table><p><a href='{{ $env.APP_BASE_URL }}/admin/verification?doc={{ $json.documentId }}' style='background:#000;color:#fff;padding:10px 20px;border-radius:6px;text-decoration:none;'>Review Document</a></p>\"\n}"
      },
      "id": "send_email_admin_ocr_summary",
      "name": "send_email_admin_ocr_summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
