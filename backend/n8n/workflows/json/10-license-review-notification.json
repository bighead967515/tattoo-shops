            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"workflow\": \"License Review Notification\",\n  \"event\": \"license_review_workflow_complete\",\n  \"documentId\": {{ $('trigger_webhook_license_review').item.json.body.documentId }},\n  \"created_at\": \"{{ new Date().toISOString() }}\"\n}"
      },
      "id": "log_supabase_license_review",
      "name": "log_supabase_license_review",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [3100, 300],
      "continueOnFail": true
    }
  ],
