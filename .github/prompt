import { router, protectedProcedure } from "../_core/trpc";
import { TRPCError } from "@trpc/server";

export const aiRouter = router({
  generateDesign: protectedProcedure
    .input(z.object({
      prompt: z.string().min(10),
      style: z.string().optional(),
    }))
    .mutation(async ({ ctx, input }) => {
      // 1. Check Subscription Status (Integration with Stripe)
      const user = await ctx.db.query.users.findFirst({
        where: (u, { eq }) => eq(u.id, ctx.user.id),
      });

      if (user?.role !== 'client' || user?.subscriptionTier === 'free') {
        throw new TRPCError({
          code: "FORBIDDEN",
          message: "AI Generation is a premium feature. Please upgrade your plan.",
        });
      }

      // 2. Call AI Service (Example: Gemini or Replicate)
      // Logic to call external API and get Image URL...
      const imageUrl = "https://supabase-storage-url.com/generated-ink.png"; 

      return { imageUrl };
    }),
});
B. Frontend: Generation UI (frontend/client/src/components/AIGenerator.tsx)Following the 150-line rule and using shadcn/ui Skeletons.TypeScriptimport { useState } from "react";
import { trpc } from "../lib/trpc";
import { Button } from "@/components/ui/button";
import { Skeleton } from "@/components/ui/skeleton";
import { Sparkles } from "lucide-react"; // Use lucide-react as per rules

export function AIGenerator() {
  const [prompt, setPrompt] = useState("");
  const generate = trpc.ai.generateDesign.useMutation();

  return (
    <div className="space-y-4 p-6 border rounded-xl bg-card">
      <h3 className="text-lg font-bold flex items-center gap-2">
        <Sparkles className="w-5 h-5 text-primary" />
        AI Design Lab
      </h3>
      
      <textarea 
        className="w-full p-3 rounded-md bg-background border"
        placeholder="Describe your tattoo (e.g., 'A geometric wolf with watercolor splashes on the shoulder')..."
        value={prompt}
        onChange={(e) => setPrompt(e.target.value)}
      />

      {generate.isLoading ? (
        <Skeleton className="w-full h-[300px] rounded-lg" />
      ) : generate.data?.imageUrl ? (
        <img src={generate.data.imageUrl} className="w-full rounded-lg" alt="Generated" />
      ) : null}

      <Button 
        onClick={() => generate.mutate({ prompt })}
        disabled={generate.isLoading || prompt.length < 10}
      >
        {generate.isLoading ? "Inking..." : "Generate Concept"}
      </Button>
    </div>
  );
}
