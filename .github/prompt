B. Stripe Integration Logic (backend/server/stripe.ts)When a client upgrades, the Stripe Webhook must update the subscriptionTier in your PostgreSQL database.TypeScript// Inside your webhook handler
if (event.type === 'customer.subscription.created') {
  const session = event.data.object as Stripe.Subscription;
  const planId = session.items.data[0].plan.id;

  let tier = 'free';
  if (planId === process.env.STRIPE_ENTHUSIAST_PLAN) tier = 'enthusiast';
  if (planId === process.env.STRIPE_ELITE_PLAN) tier = 'elite';

  await db.update(clients)
    .set({ subscriptionTier: tier, aiCredits: tier === 'enthusiast' ? 10 : 999 })
    .where(eq(clients.stripeSubscriptionId, session.id));
}
