# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication & Security
JWT_SECRET=your-secure-32-character-secret-here-change-this

# Supabase (service key is secret; anon key is public)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-public-key-here

# Frontend Supabase (public values)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
# Optional frontend branding
# VITE_APP_TITLE=Ink Connect
# VITE_APP_DESCRIPTION=Connecting tattoo clients with artists through AI-powered tools.
# Optional frontend analytics (Google Analytics 4)
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Artist Subscription Stripe Price IDs (Required)
# Create these in Stripe Dashboard and copy the Price IDs (starts with price_)
STRIPE_ARTIST_AMATEUR_PRICE_ID_MONTH=price_your_amateur_monthly_price_id
STRIPE_ARTIST_AMATEUR_PRICE_ID_YEAR=price_your_amateur_yearly_price_id
STRIPE_ARTIST_PRO_PRICE_ID_MONTH=price_your_pro_monthly_price_id
STRIPE_ARTIST_PRO_PRICE_ID_YEAR=price_your_pro_yearly_price_id
STRIPE_ARTIST_ICON_PRICE_ID_MONTH=price_your_icon_monthly_price_id
STRIPE_ARTIST_ICON_PRICE_ID_YEAR=price_your_icon_yearly_price_id
STRIPE_FOUNDING_ARTIST_PRICE_ID=price_your_founding_artist_price_id

# Client subscription product price IDs (Required if client billing rollout is active)
STRIPE_CLIENT_PLUS_PRICE_ID=price_your_plus_tier_price_id
STRIPE_CLIENT_ELITE_PRICE_ID=price_your_elite_tier_price_id


# Email Service
RESEND_API_KEY=re_your_resend_api_key

# AI Services
GROQ_API_KEY=gsk_your_groq_api_key
HUGGINGFACE_API_KEY=hf_your_huggingface_key
OPENAI_API_KEY=sk_your_openai_api_key

# Optional AI model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# HUGGINGFACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# HUGGINGFACE_CAPTION_MODEL=Salesforce/blip-image-captioning-large
# HUGGINGFACE_OCR_MODEL=microsoft/trocr-base-printed

# Admin Configuration
OWNER_OPEN_ID=your-admin-user-identifier

# Environment
NODE_ENV=development

# Optional: Error Tracking
# SENTRY_DSN=your_sentry_dsn

# Server Configuration
PORT=3000

# CORS & Domains Configuration (Optional)
# CORS_ALLOWED_ORIGINS=https://theinkednetwork.website,https://www.theinkednetwork.website
# PUBLIC_BASE_URL=https://theinkednetwork.website

# n8n Workflow Integration (Optional)
# Base URL of your n8n cloud or self-hosted instance:
# N8N_WEBHOOK_URL=https://your-name.app.n8n.cloud
# A secure token you generate to authenticate webhooks sent to n8n:
# N8N_WEBHOOK_SECRET=your-secure-authorization-token
# The specific webhook endpoint URLs generated by n8n workflows:
# N8N_ONBOARDING_WEBHOOK_URL=https://your-name.app.n8n.cloud/webhook/onboarding-trigger-path
# N8N_VERIFICATION_WEBHOOK_URL=https://your-name.app.n8n.cloud/webhook/verification-trigger-path