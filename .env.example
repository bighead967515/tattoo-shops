# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication & Security
JWT_SECRET=your-secure-32-character-secret-here-change-this

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-public-key-here

# Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service
RESEND_API_KEY=re_your_resend_api_key

# AI Service (Optional - Choose one)
GOOGLE_AI_API_KEY=AIza_your_google_ai_key
# OPENAI_API_KEY=sk-proj-your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key

# Maps (Optional)
# MAPTILER_API_KEY=your_maptiler_key
# VITE_MAPTILER_API_KEY=your_maptiler_key_for_frontend

# Admin Configuration
OWNER_OPEN_ID=your-admin-user-identifier

# Environment
NODE_ENV=development

# Optional: Error Tracking
# SENTRY_DSN=your_sentry_dsn

# Server Configuration
PORT=3000