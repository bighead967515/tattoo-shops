# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication & Security
JWT_SECRET=your-secure-32-character-secret-here-change-this

# Supabase (service key is secret; anon key is public)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-public-key-here

# Frontend Supabase (public values)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
# Optional frontend branding
# VITE_APP_TITLE=Universal Inc.

# Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Optional: Stripe client subscription product price IDs
# STRIPE_CLIENT_PLUS_PRICE_ID=price_your_plus_tier_price_id
# STRIPE_CLIENT_ELITE_PRICE_ID=price_your_elite_tier_price_id

# Email Service
RESEND_API_KEY=re_your_resend_api_key

# AI Services
GROQ_API_KEY=gsk_your_groq_api_key
HUGGINGFACE_API_KEY=hf_your_huggingface_key

# Optional AI model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# HUGGINGFACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# HUGGINGFACE_CAPTION_MODEL=Salesforce/blip-image-captioning-large
# HUGGINGFACE_OCR_MODEL=microsoft/trocr-base-printed

# Admin Configuration
OWNER_OPEN_ID=your-admin-user-identifier

# Environment
NODE_ENV=development

# Optional: Error Tracking
# SENTRY_DSN=your_sentry_dsn

# Server Configuration
PORT=3000