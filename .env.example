# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication & Security
JWT_SECRET=your-secure-32-character-secret-here-change-this

# Supabase (service key is secret; anon key is public)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-public-key-here

# Frontend Supabase (public values)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
# Optional frontend branding
# VITE_APP_TITLE=Ink Connect
# VITE_APP_DESCRIPTION=Connecting tattoo clients with artists through AI-powered tools.
# Optional frontend analytics (Google Analytics 4)
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_ARTIST_AMATEUR_PRICE_ID_MONTH=price_your_artist_amateur_month
STRIPE_ARTIST_AMATEUR_PRICE_ID_YEAR=price_your_artist_amateur_year
STRIPE_ARTIST_PRO_PRICE_ID_MONTH=price_your_artist_pro_month
STRIPE_ARTIST_PRO_PRICE_ID_YEAR=price_your_artist_pro_year
STRIPE_ARTIST_ICON_PRICE_ID_MONTH=price_your_artist_icon_month
STRIPE_ARTIST_ICON_PRICE_ID_YEAR=price_your_artist_icon_year
STRIPE_FOUNDING_ARTIST_PRICE_ID=price_your_founding_artist_month

# Client request add-on Stripe Price IDs (optional, leave blank to disable)
STRIPE_ADDON_PRIORITY_LISTING_PRICE_ID=price_addon_priority_placeholder
STRIPE_ADDON_IN_APP_CHAT_PRICE_ID=price_addon_chat_placeholder
STRIPE_ADDON_AI_DESIGN_PRICE_ID=price_addon_ai_placeholder
STRIPE_ADDON_BLIND_BIDS_PRICE_ID=price_addon_blind_placeholder

# Artist token pack Stripe Price IDs (optional, leave blank to disable)
STRIPE_ARTIST_BID_TOKEN_5_PRICE_ID=price_bid5_placeholder
STRIPE_ARTIST_BID_TOKEN_10_PRICE_ID=price_bid10_placeholder
STRIPE_ARTIST_BID_TOKEN_20_PRICE_ID=price_bid20_placeholder
STRIPE_ARTIST_CHAT_TOKEN_PACK_PRICE_ID=price_chatpack_placeholder

# Email Service
RESEND_API_KEY=re_your_resend_api_key

# AI Services
GROQ_API_KEY=gsk_your_groq_api_key
HUGGINGFACE_API_KEY=hf_your_huggingface_key

# Optional AI model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# HUGGINGFACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# HUGGINGFACE_CAPTION_MODEL=Salesforce/blip-image-captioning-large
# HUGGINGFACE_OCR_MODEL=microsoft/trocr-base-printed

# Admin Configuration
OWNER_OPEN_ID=your-admin-user-identifier

# Environment
NODE_ENV=development

# Optional: Error Tracking
# SENTRY_DSN=your_sentry_dsn

# Server Configuration
PORT=3000